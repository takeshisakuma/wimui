{
  "name": "wimui",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "dist/wimui.umd.js",
  "module": "dist/wimui.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/wimui.es.js",
      "require": "./dist/wimui.umd.js"
    }
  },
  "size-limit": [
    {
      "name": "ES Module (all chunks, gzip)",
      "path": [
        "dist/*.js",
        "!dist/wimui.umd.js"
      ],
      "gzip": true,
      "limit": "440 kB"
    },
    {
      "name": "UMD Bundle (gzip)",
      "path": "dist/wimui.umd.js",
      "gzip": true,
      "limit": "350 kB"
    }
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "size": "size-limit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:check": "node scripts/generate-missing-tests-report.cjs",
    "test:report": "npm run test:coverage && npm run test:check",
    "prestorybook": "npx kill-port 6006",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "rimraf storybook-static && storybook build",
    "format": "prettier --write .",
    "lint": "eslint src stories --ignore-pattern \"**/*.mdx\" --max-warnings=0",
    "lint:fix": "eslint src stories --ignore-pattern \"**/*.mdx\" --fix --max-warnings=0",
    "stylelint:css": "stylelint \"{src,stories}/**/*.css\" --allow-empty-input",
    "stylelint:scss": "stylelint \"{src,stories}/**/*.scss\"",
    "stylelint": "npm run stylelint:css && npm run stylelint:scss",
    "stylelint:fix": "stylelint \"{src,stories}/**/*.{css,scss}\" --fix --allow-empty-input",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots",
    "test:vrt:report": "playwright show-report",
    "i18n:sync": "node scripts/sync-i18n.js",
    "i18n:check": "node scripts/check-i18n.js",
    "i18n:check:components": "node scripts/check-i18n-components.js",
    "i18n:missing": "node scripts/find_missing_keys.js",
    "check:consistency": "node scripts/check_consistency.js",
    "check:hierarchy": "node scripts/check_hierarchy.js",
    "check:stories": "node scripts/check_stories_keys.js",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takeshisakuma/wimui.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/takeshisakuma/wimui/issues"
  },
  "homepage": "./",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@google/generative-ai": "^0.24.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/eslint-config-storybook": "^4.0.0",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/prop-types": "^15.7.15",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.3",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "imagemin-gifsicle": "^7.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-svgo": "^12.0.0",
    "imagemin-webp": "^8.0.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "music-metadata": "^11.12.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "size-limit": "^12.0.1",
    "storybook": "^10.3.3",
    "storybook-react-i18next": "^10.1.1",
    "stylelint": "^17.5.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.9.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-imagemin": "^0.6.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "node scripts/tsc-check.js"
    ],
    "src/**/*.{css,scss}": [
      "stylelint --fix --max-warnings=0"
    ],
    "public/locales/**/*.json": [
      "npm run i18n:check"
    ]
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@storybook/addon-mcp": "^0.4.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.18.0",
    "classnames": "^2.5.1",
    "dotenv": "^17.3.1",
    "i18next": "^25.10.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "jsmediatags": "^3.9.7",
    "qrcode.react": "^4.2.0",
    "react-i18next": "^16.6.2",
    "react-markdown": "^10.1.0",
    "react-use": "^17.6.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1"
  }
}
